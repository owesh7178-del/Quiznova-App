[app]
title = Quiznova
package.name = quiznova
package.domain = org.quiznova
source.dir = .
source.include_exts = py,png,jpg,json
version = 1.0
requirements = python3,kivy,urllib3
orientation = portrait
fullscreen = 1
android.archs = arm64-v8a,armeabi-v7a
android.api = 33
android.minapi = 21

[buildozer]
log_level = 2
warn_on_root = 1
